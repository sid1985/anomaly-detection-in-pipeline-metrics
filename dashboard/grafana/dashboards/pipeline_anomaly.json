{
  "title": "CI/CD Pipeline Anomaly Detection",
  "uid": "pipeline-anomaly",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "tags": ["pipeline", "anomaly", "devops"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Anomalies Detected",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(pipeline_anomaly_detected_total)",
          "legendFormat": "Anomalies"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Ensemble F1 Score",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "pipeline_model_f1_score{model=\"ensemble\"}",
          "legendFormat": "F1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green",  "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "False Positive Rate",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "pipeline_false_positive_rate",
          "legendFormat": "FPR"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red",    "value": 0.10 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Build Duration Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "pipeline_build_duration_seconds",
          "legendFormat": "Build Duration"
        },
        {
          "expr": "pipeline_anomaly_threshold_seconds",
          "legendFormat": "Anomaly Threshold"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Anomaly Score — Ensemble Model",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "pipeline_anomaly_score{model=\"ensemble\"}",
          "legendFormat": "Ensemble Score"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": null },
              { "color": "red",    "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Model Performance Comparison (F1 Score)",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 6 },
      "targets": [
        { "expr": "pipeline_model_f1_score", "legendFormat": "{{model}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "green",  "value": 0.9 }
            ]
          }
        }
      },
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 7,
      "type": "row",
      "title": "ACA Live Pipeline Results",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 8,
      "type": "stat",
      "title": "ACA — F1 Score (live)",
      "gridPos": { "x": 0, "y": 25, "w": 3, "h": 4 },
      "targets": [{ "expr": "aca_model_f1_score{model=\"isolation_forest_aca\"}", "legendFormat": "F1" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "steps": [{"color":"red","value":null},{"color":"yellow","value":0.6},{"color":"green","value":0.85}] }
        }
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "ACA — Precision",
      "gridPos": { "x": 3, "y": 25, "w": 3, "h": 4 },
      "targets": [{ "expr": "aca_model_precision{model=\"isolation_forest_aca\"}", "legendFormat": "Precision" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "ACA — Recall",
      "gridPos": { "x": 6, "y": 25, "w": 3, "h": 4 },
      "targets": [{ "expr": "aca_model_recall{model=\"isolation_forest_aca\"}", "legendFormat": "Recall" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "ACA — FPR",
      "gridPos": { "x": 9, "y": 25, "w": 3, "h": 4 },
      "targets": [{ "expr": "aca_model_fpr{model=\"isolation_forest_aca\"}", "legendFormat": "FPR" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":0.05},{"color":"red","value":0.10}] }
        }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "ACA — Pipeline Runs",
      "gridPos": { "x": 0, "y": 29, "w": 3, "h": 3 },
      "targets": [{ "expr": "aca_run_count_total", "legendFormat": "Runs" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "ACA — Anomalies Detected",
      "gridPos": { "x": 3, "y": 29, "w": 3, "h": 3 },
      "targets": [{ "expr": "aca_anomaly_detected", "legendFormat": "Detected" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"blue","value":null}] } } }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "ACA — Ground Truth Anomalies",
      "gridPos": { "x": 6, "y": 29, "w": 3, "h": 3 },
      "targets": [{ "expr": "aca_anomaly_groundtruth", "legendFormat": "Ground Truth" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 15,
      "type": "bargauge",
      "title": "ACA vs Synthetic — F1 Score Comparison",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 6 },
      "targets": [
        { "expr": "aca_model_f1_score", "legendFormat": "{{model}}" },
        { "expr": "pipeline_model_f1_score{model=~\"ensemble|isolation_forest\"}", "legendFormat": "synth-{{model}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "steps": [{"color":"red","value":null},{"color":"yellow","value":0.6},{"color":"green","value":0.85}] }
        }
      },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 16,
      "type": "bargauge",
      "title": "ACA — Detection Rate by Anomaly Kind",
      "gridPos": { "x": 0, "y": 38, "w": 12, "h": 5 },
      "targets": [{ "expr": "aca_detection_rate", "legendFormat": "{{anomaly_kind}}" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "steps": [{"color":"red","value":null},{"color":"yellow","value":0.5},{"color":"green","value":0.8}] }
        }
      },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ],
  "time": { "from": "now-6h", "to": "now" }
}
